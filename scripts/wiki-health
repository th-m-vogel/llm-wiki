#!/usr/bin/env bash
# wiki-health — run a structural health check on an agent-maintained wiki
#
# Usage:
#   wiki-health --wiki <path>
#   wiki-health --wiki <path> --json      # machine-readable output
#
# Checks:
#   [provenance]     source pages missing provenance: frontmatter
#   [orphan]         concept/source pages not listed in their index files
#   [stale-log]      wiki/log.md not updated in >48h
#   [empty-inbox]    raw/inbox/ has unprocessed files
#   [broken-link]    wikilinks pointing to non-existent pages (basic scan)
#   [no-concepts]    wiki/concepts/ is empty or missing
#   [no-sources]     wiki/sources/ is empty or missing
#   [stub-map]       map pages contain unfilled stub patterns (WARN)
#   [unmapped]       source/concept/decision/synthesis pages not referenced from any map (WARN)
#   [quality-floor]  concept pages with very low word count and no outbound links (WARN)
#   [url-reachable]  fetch-source pages with unreachable URLs (WARN)
#
# Exit 0 = healthy (or only warnings). Exit 2 = errors found.

set -euo pipefail

WIKI=""
JSON_MODE=false
ERRORS=0
WARNINGS=0

declare -a REPORT=()

usage() {
  grep '^#' "$0" | grep -v '#!/' | sed 's/^# \{0,2\}//'
  exit 1
}

flag() {
  local level="$1" check="$2" msg="$3"
  REPORT+=("[$level][$check] $msg")
  if [[ "$level" == "ERROR" ]]; then ((ERRORS++)) || true; fi
  if [[ "$level" == "WARN"  ]]; then ((WARNINGS++)) || true; fi
}

ok() {
  local check="$1" msg="$2"
  REPORT+=("[OK][$check] $msg")
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --wiki)   WIKI="$2"; shift 2 ;;
    --json)   JSON_MODE=true; shift ;;
    --help|-h) usage ;;
    *) echo "Unknown argument: $1" >&2; exit 1 ;;
  esac
done

if [[ -z "$WIKI" ]]; then
  echo "ERROR: --wiki <path> is required" >&2
  exit 1
fi

WIKI="$(realpath "$WIKI")"

if [[ ! -f "$WIKI/README.md" ]]; then
  echo "ERROR: $WIKI/README.md not found — is this a valid wiki root?" >&2
  exit 1
fi

# --- Check: wiki/sources/ exists and is non-empty ---
if [[ ! -d "$WIKI/wiki/sources" ]]; then
  flag ERROR no-sources "wiki/sources/ directory missing"
elif [[ -z "$(find "$WIKI/wiki/sources" -name "*.md" | head -1)" ]]; then
  flag WARN no-sources "wiki/sources/ exists but contains no .md files"
else
  COUNT=$(find "$WIKI/wiki/sources" -name "*.md" | wc -l | tr -d ' ')
  ok no-sources "$COUNT source page(s) found"
fi

# --- Check: wiki/concepts/ exists and is non-empty ---
if [[ ! -d "$WIKI/wiki/concepts" ]]; then
  flag ERROR no-concepts "wiki/concepts/ directory missing"
elif [[ -z "$(find "$WIKI/wiki/concepts" -name "*.md" | head -1)" ]]; then
  flag WARN no-concepts "wiki/concepts/ exists but contains no .md files"
else
  COUNT=$(find "$WIKI/wiki/concepts" -name "*.md" | wc -l | tr -d ' ')
  ok no-concepts "$COUNT concept page(s) found"
fi

# --- Check: provenance on source pages ---
if [[ -d "$WIKI/wiki/sources" ]]; then
  MISSING_PROV=0
  while IFS= read -r f; do
    if ! grep -q "^provenance:" "$f" 2>/dev/null; then
      flag ERROR provenance "Missing provenance: frontmatter in $(basename "$f")"
      ((MISSING_PROV++)) || true
    fi
  done < <(find "$WIKI/wiki/sources" -name "*.md" 2>/dev/null | sort)
  if [[ $MISSING_PROV -eq 0 && -d "$WIKI/wiki/sources" ]]; then
    ok provenance "All source pages have provenance: frontmatter"
  fi
fi

# --- Check: orphan concept pages (not listed in wiki/concepts.md) ---
if [[ -f "$WIKI/wiki/concepts.md" && -d "$WIKI/wiki/concepts" ]]; then
  ORPHAN_C=0
  while IFS= read -r f; do
    slug="$(basename "$f" .md)"
    if ! grep -qF "$slug" "$WIKI/wiki/concepts.md"; then
      flag WARN orphan "Concept page not listed in wiki/concepts.md: $slug"
      ((ORPHAN_C++)) || true
    fi
  done < <(find "$WIKI/wiki/concepts" -name "*.md" | sort)
  if [[ $ORPHAN_C -eq 0 ]]; then
    ok orphan "All concept pages listed in wiki/concepts.md"
  fi
fi

# --- Check: orphan source pages (not listed in wiki/sources.md) ---
if [[ -f "$WIKI/wiki/sources.md" && -d "$WIKI/wiki/sources" ]]; then
  ORPHAN_S=0
  while IFS= read -r f; do
    slug="$(basename "$f" .md)"
    if ! grep -qF "$slug" "$WIKI/wiki/sources.md"; then
      flag WARN orphan "Source page not listed in wiki/sources.md: $slug"
      ((ORPHAN_S++)) || true
    fi
  done < <(find "$WIKI/wiki/sources" -name "*.md" | sort)
  if [[ $ORPHAN_S -eq 0 ]]; then
    ok orphan "All source pages listed in wiki/sources.md"
  fi
fi

# --- Check: wiki/log.md staleness ---
if [[ ! -f "$WIKI/wiki/log.md" ]]; then
  flag ERROR stale-log "wiki/log.md does not exist"
else
  LAST_MOD=$(find "$WIKI/wiki/log.md" -newer /tmp -prune -o \
    -mmin +$((48*60)) -print 2>/dev/null || true)
  # Simpler: just check mtime in hours
  NOW=$(date +%s)
  LOG_MTIME=$(stat -c %Y "$WIKI/wiki/log.md" 2>/dev/null || stat -f %m "$WIKI/wiki/log.md" 2>/dev/null || echo 0)
  AGE_H=$(( (NOW - LOG_MTIME) / 3600 ))
  if [[ $AGE_H -gt 48 ]]; then
    flag WARN stale-log "wiki/log.md last modified ${AGE_H}h ago — maintenance may have missed a run"
  else
    ok stale-log "wiki/log.md updated ${AGE_H}h ago"
  fi
fi

# --- Check: raw/inbox unprocessed files ---
if [[ -d "$WIKI/raw/inbox" ]]; then
  INBOX_COUNT=$(find "$WIKI/raw/inbox" -name "*.md" | wc -l | tr -d ' ')
  if [[ "$INBOX_COUNT" -gt 0 ]]; then
    flag WARN empty-inbox "$INBOX_COUNT file(s) in raw/inbox/ waiting for ingest"
    find "$WIKI/raw/inbox" -name "*.md" | sort | while IFS= read -r f; do
      REPORT+=("         $(basename "$f")")
    done
  else
    ok empty-inbox "raw/inbox/ is clear"
  fi
fi

# --- Check: basic broken wikilinks ---
BROKEN=0
while IFS= read -r f; do
  while IFS= read -r link; do
    # Strip alias (|...) and path prefix — just check the final slug
    target_slug=$(echo "$link" | sed 's/|.*//' | sed 's|.*/||')
    [[ -z "$target_slug" ]] && continue
    # Skip cross-vault links (contain ..) — they point outside wiki/ and can't be checked here
    echo "$link" | grep -q '\.\.' && continue
    # Check if a file with that slug exists anywhere under wiki/
    if ! find "$WIKI/wiki" -name "${target_slug}.md" 2>/dev/null | grep -q .; then
      flag WARN broken-link "Broken wikilink [[${link}]] in $(basename "$f")"
      ((BROKEN++)) || true
    fi
  done < <(grep -oP '\[\[([^\]|]+)' "$f" 2>/dev/null | sed 's/\[\[//' || true)
done < <(find "$WIKI/wiki" -name "*.md" | sort)
if [[ $BROKEN -eq 0 ]]; then
  ok broken-link "No broken wikilinks detected"
fi

# --- Check: stub patterns in map pages (Cat 1 — navigational staleness) ---
if [[ -d "$WIKI/wiki/maps" ]]; then
  STUB_PATTERNS=('<!-- populated' 'pending.*ingest' 'pending first' 'coming soon' 'to be added')
  STUB_COUNT=0
  while IFS= read -r f; do
    for pat in "${STUB_PATTERNS[@]}"; do
      if grep -qiE "$pat" "$f" 2>/dev/null; then
        flag WARN stub-map "Map page contains unfilled stub pattern ('$pat'): $(basename "$f")"
        ((STUB_COUNT++)) || true
        break
      fi
    done
    # Check for section headings with zero wikilinks in the section
    # Extract heading lines and check if next content block has any [[links]]
    python3 - "$f" << 'PYEOF' 2>/dev/null | while IFS= read -r line; do
import sys, re
path = sys.argv[1]
try:
    content = open(path).read()
except:
    sys.exit(0)
sections = re.split(r'^(#{1,3} .+)$', content, flags=re.MULTILINE)
for i in range(1, len(sections)-1, 2):
    heading = sections[i].strip()
    body = sections[i+1] if i+1 < len(sections) else ''
    # Skip the heading if it has no body or body is just whitespace/comments
    body_stripped = re.sub(r'<!--.*?-->', '', body, flags=re.DOTALL).strip()
    if body_stripped and '[[' not in body:
        print(f"{heading}")
PYEOF
      flag WARN stub-map "Map section has no wikilinks in $(basename "$f"): $line"
    done
  done < <(find "$WIKI/wiki/maps" -name "*.md" 2>/dev/null | sort)
  if [[ $STUB_COUNT -eq 0 ]]; then
    ok stub-map "No stub patterns found in map pages"
  fi
else
  flag WARN stub-map "wiki/maps/ directory missing — no navigational maps found"
fi

# --- Check: coverage drift — pages not referenced from any map (Cat 2) ---
MAP_CONTENT=""
if [[ -d "$WIKI/wiki/maps" ]]; then
  MAP_CONTENT=$(cat "$WIKI"/wiki/maps/*.md 2>/dev/null || true)
fi

_check_unmapped() {
  local dir="$1" label="$2"
  [[ -d "$dir" ]] || return
  local count=0
  while IFS= read -r f; do
    local slug
    slug="$(basename "$f" .md)"
    if [[ -n "$MAP_CONTENT" ]] && ! echo "$MAP_CONTENT" | grep -qF "$slug"; then
      flag WARN unmapped "$label page not referenced from any map: $slug"
      ((count++)) || true
    fi
  done < <(find "$dir" -name "*.md" 2>/dev/null | sort)
  if [[ $count -eq 0 && -d "$dir" ]]; then
    ok unmapped "All $label pages referenced from maps"
  fi
}

_check_unmapped "$WIKI/wiki/concepts"   "concept"
_check_unmapped "$WIKI/wiki/sources"    "source"
_check_unmapped "$WIKI/wiki/decisions"  "decision"
_check_unmapped "$WIKI/wiki/syntheses"  "synthesis"

# --- Check: concept quality floor (Cat 7) ---
if [[ -d "$WIKI/wiki/concepts" ]]; then
  STUB_CONCEPTS=0
  while IFS= read -r f; do
    word_count=$(wc -w < "$f" 2>/dev/null || echo 999)
    link_count=$(grep -oP '\[\[' "$f" 2>/dev/null | wc -l || echo 1)
    if [[ "$word_count" -lt 80 && "$link_count" -eq 0 ]]; then
      flag WARN quality-floor "Concept page appears to be a stub (<80 words, no wikilinks): $(basename "$f")"
      ((STUB_CONCEPTS++)) || true
    fi
  done < <(find "$WIKI/wiki/concepts" -name "*.md" 2>/dev/null | sort)
  if [[ $STUB_CONCEPTS -eq 0 ]]; then
    ok quality-floor "All concept pages meet minimum quality threshold"
  fi
fi

# --- Check: fetch-source URL reachability (Cat 6) ---
FETCH_DIR="$WIKI/raw/fetch-sources"
if [[ -d "$FETCH_DIR" ]]; then
  URL_FAIL=0
  while IFS= read -r f; do
    url=$(grep -m1 '^url:' "$f" 2>/dev/null | sed 's/^url: *//' | tr -d '"' || true)
    [[ -z "$url" ]] && continue
    if ! curl -sf --max-time 10 --head "$url" -o /dev/null 2>/dev/null; then
      flag WARN url-reachable "Fetch-source URL unreachable ($(basename "$f")): $url"
      ((URL_FAIL++)) || true
    fi
  done < <(find "$FETCH_DIR" -name "*.md" 2>/dev/null | sort)
  if [[ $URL_FAIL -eq 0 ]]; then
    FETCH_COUNT=$(find "$FETCH_DIR" -name "*.md" | wc -l | tr -d ' ')
    ok url-reachable "All $FETCH_COUNT fetch-source URL(s) reachable"
  fi
fi

# --- Output ---
echo "=== wiki-health: $WIKI ==="
echo ""

if [[ "$JSON_MODE" == true ]]; then
  echo '{"wiki":"'"$WIKI"'","errors":'"$ERRORS"',"warnings":'"$WARNINGS"',"results":['
  FIRST=true
  for r in "${REPORT[@]}"; do
    $FIRST && FIRST=false || echo ","
    echo -n "  $(echo "$r" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read().strip()))')"
  done
  echo ""
  echo "]}"
else
  for r in "${REPORT[@]}"; do
    echo "  $r"
  done
  echo ""
  echo "  Summary: $ERRORS error(s), $WARNINGS warning(s)"
fi

echo ""

if [[ $ERRORS -gt 0 ]]; then
  echo "HEALTH TASK"
  echo "  The wiki has $ERRORS error(s) listed above that require agent attention."
  echo "  Fix errors before warnings. Update wiki/log.md after repairs."
  exit 2
elif [[ $WARNINGS -gt 0 ]]; then
  echo "HEALTH TASK"
  echo "  The wiki has $WARNINGS warning(s) listed above. Review and fix as appropriate."
  echo "  Update wiki/log.md after any repairs made."
  exit 0
else
  echo "  Wiki is healthy. No action required."
  exit 0
fi
